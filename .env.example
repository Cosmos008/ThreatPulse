KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ADVERTISED_HOST=localhost
KAFKA_HOST_PORT=29092
KAFKA_CONNECT_RETRIES=30
KAFKA_CONNECT_RETRY_DELAY_SECONDS=2
ZOOKEEPER_PORT=2181

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=alerts
POSTGRES_USER=security
POSTGRES_PASSWORD=change-me
POSTGRES_CONNECT_RETRIES=30
POSTGRES_CONNECT_RETRY_DELAY_SECONDS=2

HONEYPOT_FILE=/app/configs/honeypot_accounts.txt
SECURITY_API_KEY=change-this-api-key
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
GEOLOCATION_PROVIDER_URL=https://ipwho.is/{ip}
GEOLOCATION_CACHE_TTL_SECONDS=3600
THREAT_INTEL_PROVIDER_URL=https://ipwho.is/{ip}
TOR_EXIT_NODES_FILE=/app/configs/tor_exit_nodes.txt
RULES_CONFIG_FILE=/app/configs/rules.yaml
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=default
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRY_MINUTES=60
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me
